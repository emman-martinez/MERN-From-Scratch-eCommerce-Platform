# Authentication
# Replace this with a long, random value. Never commit your real secret.
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_DB_NAME=proshop

NODE_ENV=development
CLIENT_URL=http://localhost:5173
PORT=5000

# Mongo URI for the backend: local Docker Mongo
# MONGO_URI=mongodb://admin:password@mongo:27017/proshop?authSource=admin

# Atlas, when you want to use it
MONGO_URI=mongodb+srv://user:password@proshop-cluster.xxxxx.mongodb.net/proshop?retryWrites=true&w=majority&appName=proshop-cluster
